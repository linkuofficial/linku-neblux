{
  "name": "neblux",
  "version": "1.0.0",
  "description": "Cross-domain knowledge graph generation and exploration platform",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/build_share_pages.mjs",
    "preview": "vite preview",
    "test:e2e": "playwright test --grep-invert @visual",
    "verify": "npm run build && npm run test:e2e",
    "test:e2e:visual": "playwright test --grep @visual",
    "test:e2e:install": "playwright install --with-deps chromium",
    "atlas:validate": "node scripts/atlas/validate.mjs",
    "test:atlas": "node --test tests/atlas/validators.test.mjs tests/atlas/layout.test.mjs",
    "atlas:layout:init": "node scripts/atlas/layout/bake-main.mjs",
    "atlas:layout:check": "node scripts/atlas/layout/check-layout.mjs",
    "atlas:layout:add": "node scripts/atlas/layout/add-node.mjs",
    "atlas:layout:wonder": "node scripts/atlas/layout/bake-wonder.mjs",
    "atlas:layout:diff": "node scripts/atlas/layout/diff-layout.mjs",
    "atlas:layout:debt": "node scripts/atlas/layout/report-layout-debt.mjs",
    "atlas:layout:bless": "node scripts/atlas/layout/bless-layout.mjs",
    "atlas:classify:propose": "node scripts/atlas/layout/classify-celestial.mjs"
  },
  "keywords": [
    "knowledge-graph",
    "education",
    "d3.js"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "sharp": "^0.35.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^6.0.3",
    "vite": "^8.0.14"
  },
  "dependencies": {
    "d3": "^7.9.0"
  }
}
